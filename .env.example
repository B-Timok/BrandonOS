# BrandonOS database configuration
#
# Local development: a libSQL/SQLite file is used by default. You can leave these
# unset to use ./local.db, or point them at a file explicitly.
#
# Production (Vercel): create a Turso database and paste its URL + auth token.
#   turso db create brandonos
#   turso db show brandonos --url
#   turso db tokens create brandonos
DATABASE_URL="file:./local.db"
DATABASE_AUTH_TOKEN=""
